# Скопируйте в переменные окружения хостинга (или в файл .env для локального запуска).

# Токен бота от @BotFather — ОБЯЗАТЕЛЬНО
BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Произвольная случайная строка — будет частью адреса вебхука оплаты
WEBHOOK_SECRET=придумайте-длинную-случайную-строку

# Цена подписки в Telegram Stars за месяц (150 ⭐ ≈ 2–3 $)
STAR_PRICE=150

# Сколько книг можно хранить бесплатно (без подписки)
FREE_LIMIT=3

# Telegram ID владельцев, которые могут наполнять общий каталог (через запятую).
# Свой ID можно узнать у бота @userinfobot. Пример: 123456789,987654321
ADMIN_IDS=123456789

# Порт (на Render/Railway подставляется автоматически — можно не трогать)
PORT=3000
